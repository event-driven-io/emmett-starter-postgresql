{
  "name": "expressjs-with-postgresql",
  "version": "1.0.0",
  "type": "module",
  "description": "Samples WebApi using Event Sourcing using Emmett, Express.js and PostgreSQL ",
  "scripts": {
    "setup": "cat .nvmrc | nvm install; nvm use",
    "build": "tsup",
    "build:ts": "tsc -b",
    "build:ts:watch": "tsc -b --watch",
    "start": "tsx ./src/index.ts",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:prettier": "prettier --check \"**/**/!(*.d).{ts,json,md}\"",
    "lint:eslint": "eslint '**/*.ts'",
    "fix": "run-s fix:eslint fix:prettier",
    "fix:prettier": "prettier --write \"**/**/!(*.d).{ts,json,md}\"",
    "fix:eslint": "eslint '**/*.ts' --fix",
    "test": "run-s test:unit test:int test:e2e",
    "test:unit": "glob-bin -d -c \"node --import tsx --test\" **/*.unit.spec.ts",
    "test:int": "glob-bin -d -c \"node --import tsx --test\" **/*.int.spec.ts",
    "test:e2e": "glob-bin -d -c \"node --import tsx --test\" **/*.e2e.spec.ts",
    "test:watch": "run-p test:unit:watch test:int:watch test:e2e:watch",
    "test:unit:watch": "glob-bin -d -c \"node --import tsx --test --watch\" **/*.unit.spec.ts",
    "test:int:watch": "glob-bin -d -c \"node --import tsx --test --watch\" **/*.int.spec.ts",
    "test:e2e:watch": "glob-bin -d -c \"node --import tsx --test --watch\" **/*.e2e.spec.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oskardudycz/EventSourcing.NodeJS.git"
  },
  "keywords": [
    "Event Sourcing"
  ],
  "author": "Oskar Dudycz",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/oskardudycz/EventSourcing.NodeJS/issues"
  },
  "homepage": "https://github.com/oskardudycz/EventSourcing.NodeJS#readme",
  "dependencies": {
    "@event-driven-io/emmett-postgresql": "0.43.0-beta.6",
    "@event-driven-io/emmett-expressjs": "0.43.0-beta.6",
    "pg": "^8.17.2"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "@types/node": "^25.0.10",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "glob-bin": "^1.0.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "tsup": "^8.5.1",
    "@testcontainers/postgresql": "^11.11.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
